# Copy to .env for local dev. Do NOT commit the real .env.

DATABASE_URL="sqlite:golf.db"
PORT=3000

# Scheduler is dry-run by default; set to false to make REAL bookings.
DRY_RUN=true

# Session cookie is Secure (HTTPS-only) by default. For local plain-HTTP dev,
# set this to false or the browser will never send the cookie back.
COOKIE_SECURE=false

# Optional: seed the first app user (login) on an empty database.
# APP_USERNAME=admin
# APP_PASSWORD=change-me

# Optional: seed clubs on an empty database (clubs are otherwise managed in the
# UI at /clubs). Each club needs all four *_BASE_URL/USERNAME/PASSWORD/MEMBER_ID
# vars; *_TIMEZONE is optional and defaults to Australia/Sydney.
# RIDGE_BASE_URL="https://theridgegolf.com.au"
# RIDGE_USERNAME=
# RIDGE_PASSWORD=
# RIDGE_MEMBER_ID=
# RIDGE_TIMEZONE=Australia/Sydney
# NSW_BASE_URL="https://nswgolfclub.com.au"
# NSW_USERNAME=
# NSW_PASSWORD=
# NSW_MEMBER_ID=
